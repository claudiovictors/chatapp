 481 | <script>
 482 | function previewAvatar(input) {
 483 |     if (input.files && input.files[0]) {
 484 |         const reader = new FileReader();
 485 |         reader.onload = function(e) {
 486 |             const wrap = document.getElementById('avatarWrap');
 487 |             // Remove initials div if present
 488 |             const initials = document.getElementById('avatarInitials');
 489 |             if (initials) initials.remove();
 490 | 
 491 |             let img = document.getElementById('avatarPreview');
 492 |             if (!img) {
 493 |                 img = document.createElement('img');
 494 |                 img.id = 'avatarPreview';
 495 |                 img.className = 'edit-avatar-img';
 496 |                 wrap.insertBefore(img, wrap.querySelector('label'));
 497 |             }
 498 |             img.src = e.target.result;
 499 |         };
 500 |         reader.readAsDataURL(input.files[0]);
 501 |     }
 502 | }
 503 | 
 504 | // Bio character counter
 505 | const bioTextarea = document.querySelector('textarea[name="bio"]');
 506 | const bioCount = document.getElementById('bioCount');
 507 | if (bioTextarea && bioCount) {
 508 |     bioTextarea.addEventListener('input', function() {
 509 |         bioCount.textContent = this.value.length;
 510 |     });
 511 | }
 512 | </script>
